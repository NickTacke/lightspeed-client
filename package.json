{
  "name": "lightspeed-client",
  "version": "0.2.1",
  "description": "typescript client for the lightspeed ecom (c-series) api",
  "type": "module",
  "license": "MIT",
  "author": "NickTacke",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NickTacke/lightspeed-client.git"
  },
  "homepage": "https://github.com/NickTacke/lightspeed-client#readme",
  "bugs": {
    "url": "https://github.com/NickTacke/lightspeed-client/issues"
  },
  "keywords": [
    "lightspeed",
    "ecom",
    "ecommerce",
    "webshopapp",
    "shoplightspeed",
    "api-client",
    "c-series"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check . && tsc --noEmit && bun test",
    "prepublishOnly": "bun run build",
    "ci:version": "changeset version && biome format --write package.json",
    "release": "changeset publish"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/bun": "^1.1.0",
    "@types/node": "^20",
    "lefthook": "^1.7.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
